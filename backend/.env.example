GROQ_API_KEY=your_groq_api_key_here

# Dedicated PostgreSQL container for THIS project (port 5433)
# Start with: docker compose up -d
DATABASE_URL=postgresql://hcp_user:hcp_password@localhost:5433/hcp_crm

# Dev fallback only:
# DATABASE_URL=sqlite:///./hcp_crm.db

# Assignment allows: gemma2-9b-it OR llama-3.3-70b-versatile
# gemma2-9b-it was decommissioned by Groq — use assignment-approved alternative:
GROQ_MODEL=llama-3.3-70b-versatile
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
